\section{Methodology}


\subsection{Heston Model}

The Heston model prices European options using the characteristic function method with Black-Scholes pricing as the baseline. Parameters calibrated:

\begin{equation}
\Theta = \{\nu_0, \theta, \rho, \kappa, \sigma\}
\end{equation}

where:
\begin{itemize}
    \item $\nu_0$ = Initial instantaneous variance (annualized)
    \item $\theta$ = Long-run mean variance
    \item $\rho$ = Correlation between spot and volatility
    \item $\kappa$ = Mean reversion speed
    \item $\sigma$ = Volatility of volatility
\end{itemize}

\subsection{Calibration Approach}

\begin{itemize}
    \item \textbf{Optimization Strategy}: 
    \begin{itemize}
        \item \textit{Price-based objectives} (SSE, Vega-Weighted, Relative): L-BFGS-B with bounds, max 1,000 iterations
        \item \textit{Implied Volatility objective}: Differential Evolution (global optimizer) with 500 iterations, seed=42
    \end{itemize}
    
    \item \textbf{Rationale for Multi-Method Approach}: 
    \begin{itemize}
        \item L-BFGS-B efficient for smooth, convex price-based objectives
        \item Differential Evolution required for IV objective due to noisy calculations and multiple local minima
        \item IV objective normalized by market volatility scale to prevent numerical instability
    \end{itemize}
    
    \item \textbf{Cross-Validation}: 5-fold KFold split (non-stratified, $n=47$ options insufficient for stratification)
    \begin{itemize}
        \item Evaluates out-of-sample generalization and parameter stability
        \item Captures parameter variation across data subsets
    \end{itemize}
    
    \item \textbf{Parameter Bounds}:
    \begin{itemize}
        \item $\nu_0 \in [0.001, 1.0]$ (initial variance)
        \item $\theta \in [0.001, 1.0]$ (long-term variance)
        \item $\kappa \in [0.01, 10.0]$ (mean reversion speed)
        \item $\sigma \in [0.01, 2.0]$ (volatility of volatility)
        \item $\rho \in [-0.999, 0.999]$ (correlation)
    \end{itemize}
    
\end{itemize}

\subsection{Performance Metrics}

\begin{itemize}
    \item \textbf{In-Sample}: Fit quality on the calibration dataset
    \item \textbf{Out-of-Sample (OOS)}: Predictive performance on held-out test folds
    \item \textbf{Generalization Gap}: OOS metric minus in-sample metric (negative = good, indicates model does not overfit)
    \item \textbf{Parameter Std Dev}: Standard deviation of calibrated parameters across folds (lower = more stable)
\end{itemize}


