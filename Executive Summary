\section*{Abbreviations and Notation}

\begin{itemize}
    \item \textbf{OOS} = Out-of-sample (test set performance)
    \item \textbf{L-BFGS-B} = Limited-memory BFGS with box constraints (quasi-Newton optimization algorithm)
    \item \textbf{RMSE} = Root mean squared error
    \item \textbf{Relative RMSE} = RMSE expressed as percentage of mean option price
    \item \textbf{MAE} = Mean absolute error
    \item \textbf{SSE} = Sum of squared errors
    \item \textbf{IV} = Implied volatility
    \item \textbf{ATM} = At-the-money
    \item \textbf{OTM} = Out-of-the-money
    \item \textbf{DTE} = Days to expiration
    \item \textbf{P\&L} = Profit and loss
\end{itemize}

\section{Introduction}


We compare four objective functions for calibrating the Heston model to market option prices:
\begin{enumerate}
    \item \textbf{Sum of Squared Errors (SSE)} -- Minimize absolute price differences
    \begin{equation}
    G(\Theta) = \sum_{i = 1}^N (C_i^{\text{model}}(\Theta) - C_i^\text{market})^2
    \end{equation}
    
    \item \textbf{Vega-Weighted} -- Emphasize liquid, near-ATM options
    \begin{equation}
    G(\Theta) = \sum_{i = 1}^N \nu_i \cdot (C_i^{\text{model}}(\Theta) - C_i^\text{market})^2
    \end{equation}
    where $\nu_i$ is the vega (dollar sensitivity to volatility) of option $i$, normalized across all options.
    
    \item \textbf{Relative Errors} -- Minimize percentage price deviations
    \begin{equation}
    G(\Theta) = \sum_{i = 1}^N\left(\frac{C_i^{\text{model}}(\Theta) - C_i^\text{market}}{C_i^{\text{market}}}\right)^2
    \end{equation}
    
    \item \textbf{Implied Volatility (IV)} -- Match volatility surface directly
    \begin{equation}
    G(\Theta) = \sum_{i = 1}^N (IV_i^\text{model}(\Theta) - IV_i^\text{market})^2
    \end{equation}
\end{enumerate}

Objective functions are compared based on three criteria: (1) \textit{in-sample accuracy}, measuring fit to calibration data; (2) \textit{out-of-sample (OOS) prediction}, measuring generalization to unseen data via cross-validation; and (3) \textit{parameter robustness}, measuring stability of Heston parameters across different data splits.


